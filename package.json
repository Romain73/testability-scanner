{
  "name": "testability-scanner",
  "version": "0.1.0",
  "description": "Static analysis tool that audits your web app's testability score",
  "type": "module",
  "bin": {
    "testability-scanner": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepare": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "playwright": "^1.43.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.12.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.1"
  }
}
